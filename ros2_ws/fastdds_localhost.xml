<?xml version="1.0" encoding="UTF-8" ?>
<dds xmlns="http://www.eprosima.com/XMLSchemas/fastrtps_profile">
    <profiles>
        <transport_descriptors>
            <!-- UDPv4 transport restricted to loopback (localhost) -->
            <transport_descriptor>
                <transport_id>udp_localhost</transport_id>
                <type>UDPv4</type>
                <interfaceWhiteList>
                    <address>127.0.0.1</address>
                </interfaceWhiteList>
            </transport_descriptor>

            <!-- Shared Memory transport (retains fast local communication) -->
            <transport_descriptor>
                <transport_id>shm_transport</transport_id>
                <type>SHM</type>
            </transport_descriptor>
        </transport_descriptors>

        <!-- Default participant profile for all standard ROS2 nodes -->
        <participant profile_name="default_profile" is_default_profile="true">
            <rtps>
                <useBuiltinTransports>false</useBuiltinTransports>
                <userTransports>
                    <transport_id>udp_localhost</transport_id>
                    <transport_id>shm_transport</transport_id>
                </userTransports>
            </rtps>
        </participant>

        <!-- Specific profile matching the micro-ROS Agent participant name -->
        <participant profile_name="default_xrce_participant">
            <rtps>
                <useBuiltinTransports>false</useBuiltinTransports>
                <userTransports>
                    <transport_id>udp_localhost</transport_id>
                    <transport_id>shm_transport</transport_id>
                </userTransports>
            </rtps>
        </participant>
    </profiles>
</dds>
